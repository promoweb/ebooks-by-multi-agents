# BookWriterAI - Environment Configuration
# Copia questo file in .env e inserisci le tue chiavi API

# =============================================================================
# OPENAI API
# =============================================================================
# Ottieni la tua chiave da: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-sp-12345

# =============================================================================
# BAILIAN API (Alibaba Cloud Coding Plan / OpenClaw)
# =============================================================================
# Ottieni la tua chiave da: https://dashscope.aliyun.com/
# Endpoint: https://coding-intl.dashscope.aliyuncs.com/v1 (OpenAI-compatible)
# Modelli supportati: qwen3.5-plus, qwen3-max-2026-01-23, qwen3-coder-next,
#                     qwen3-coder-plus, MiniMax-M2.5, glm-5, glm-4.7, kimi-k2.5
BAILIAN_API_KEY=sk-sp-12345

# =============================================================================
# DASHSCOPE API (Alibaba Cloud - Legacy API nativa)
# =============================================================================
# Ottieni la tua chiave da: https://dashscope.aliyun.com/
# Nota: Questa è l'API legacy nativa. Per nuovi progetti, usa BAILIAN_API_KEY
DASHSCOPE_API_KEY=sk-sp-12345
# =============================================================================
# AZURE OPENAI (opzionale)
# =============================================================================
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-01

# =============================================================================
# ALTRE CONFIGURAZIONI (opzionali)
# =============================================================================
# LOG_LEVEL=INFO
# PYTHONUNBUFFERED=1
